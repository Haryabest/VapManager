[General]
db_driver=psql
db_host=192.168.0.1
db_port=5432
db_name=agv_manager_db
db_user=vapmanager
db_password=51525354
language=ru

[Opc]
# Включить интеграцию с OPC-сервером (пока через заглушку).
opc_enabled=false
# Адрес OPC UA, например opc.tcp://192.168.0.1:4840
opc_endpoint=
# Интервал опроса телеметрии (мс)
opc_poll_interval_ms=3000
# Режим заглушки до подключения реального OPC-клиента
opc_stub_mode=true
# Принудительно симулировать обрыв связи с OPC-сервером
opc_stub_force_disconnected=false
# AGV с потерей связи на уровне OPC (создаётся ошибка «Ошибка связи с AGV»)
opc_offline_agv_ids=
# AGV, которые приходят только из OPC (автоподгрузка), через запятую
opc_extra_agv_ids=
